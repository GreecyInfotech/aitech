# PostgreSQL
DATABASE_URL=postgresql+psycopg://postgres:admin@localhost:5432/postgres
USE_SEED_DATA=false

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email Configuration (Optional — enables live campaign delivery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
CAMPAIGN_FORCE_DEMO_MODE=false
CAMPAIGN_SENDER_LIMIT=500
CAMPAIGN_EMAIL_DELAY_SECONDS=1

# API Keys (Optional)
APOLLO_API_KEY=
HUNTER_API_KEY=
LINKEDIN_API_KEY=

# Apify — live LinkedIn job scraping (https://apify.com/api/job-scraping-api)
APIFY_API_TOKEN=
USE_APIFY_SCRAPER=true
APIFY_ACTOR_ID=curious_coder/linkedin-jobs-scraper
APIFY_JOBS_PER_SEARCH=25
APIFY_MAX_WAIT_SECONDS=120

# Sales Automation / Job boards — embeddings + optional LLM reasoning
USE_LOCAL_LLM=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT_SECONDS=120
RESUME_PARSE_LLM_TIMEOUT_SECONDS=10
RESUME_PARSE_INCLUDE_LLM=false
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BACKEND=sklearn_tfidf
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Feature Flags
ENABLE_CAMPAIGN_MODULE=true
ENABLE_JOB_AUTOMATION=true
ENABLE_LINKEDIN_RECRUITER=true
ENABLE_REPORTING=true
